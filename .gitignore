# --------------------------------------------------
# Terraform local working directory
# Contains downloaded providers, modules and cache.
# Can be recreated using: terraform init
# --------------------------------------------------
.terraform/

# --------------------------------------------------
# Terraform state files
# Store the current state of infrastructure.
# Never commit these files.
# --------------------------------------------------
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.d/

# --------------------------------------------------
# Variable files
# Often contain secrets, passwords, subscription IDs,
# service principal credentials, etc.
# --------------------------------------------------
*.tfvars
*.tfvars.json

# --------------------------------------------------
# Terraform execution plans
# Generated by terraform plan -out
# Environment specific and should not be versioned.
# --------------------------------------------------
*.tfplan
*plan.out

# --------------------------------------------------
# Crash logs
# Generated when Terraform crashes.
# Useful only for local troubleshooting.
# --------------------------------------------------
crash.log
crash.*.log

# --------------------------------------------------
# Override files
# Used to override configuration locally.
# Not intended for team collaboration.
# --------------------------------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --------------------------------------------------
# Terraform lock information
# Temporary lock file during apply operations.
# --------------------------------------------------
*.terraform.tfstate.lock.info

# --------------------------------------------------
# Terraform CLI configuration
# May contain local user-specific settings.
# --------------------------------------------------
.terraformrc
terraform.rc
providers/